{
  "name": "@agent-runtime/cli",
  "version": "0.3.0",
  "description": "CLI for agent-runtime - chat, login, cookie management",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "agent-runtime": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js"
  },
  "license": "MIT",
  "dependencies": {
    "@agent-runtime/agent": "workspace:*",
    "@agent-runtime/browser": "workspace:*",
    "@agent-runtime/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3"
  }
}
