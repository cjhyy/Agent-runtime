{
  "name": "@agent-runtime/mcp-playwright",
  "version": "0.3.0",
  "description": "MCP Server exposing headless Playwright browser tools (headless_*)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "mcp-playwright": "dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch"
  },
  "license": "MIT",
  "dependencies": {
    "@agent-runtime/core": "workspace:*",
    "@agent-runtime/browser": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3"
  }
}
