{
  "name": "agent-runtime",
  "version": "0.3.0",
  "private": true,
  "description": "Browser automation infrastructure - monorepo",
  "scripts": {
    "build": "pnpm -r build",
    "build:core": "pnpm --filter @agent-runtime/core build",
    "build:browser": "pnpm --filter @agent-runtime/browser build",
    "build:mcp": "pnpm --filter @agent-runtime/mcp-playwright build && pnpm --filter @agent-runtime/mcp-sdk-bridge build",
    "build:server": "pnpm --filter @agent-runtime/server build",
    "build:sdk": "pnpm --filter @agent-runtime/sdk build",
    "dev": "pnpm -r --parallel dev",
    "mcp:playwright": "node packages/mcp-playwright/dist/index.js",
    "server": "node packages/server/dist/cli.js",
    "demo": "pnpm --filter demo dev",
    "clean": "pnpm -r exec rm -rf dist"
  },
  "devDependencies": {
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18"
  }
}
